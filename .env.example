# === 업비트 API ===
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# === 텔레그램 ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLL_TIMEOUT_SECONDS=20
TELEGRAM_REQUEST_TIMEOUT_SECONDS=30
TELEGRAM_POLL_BACKOFF_INITIAL_SECONDS=1.0
TELEGRAM_POLL_BACKOFF_MAX_SECONDS=30.0

# === 거래 설정 ===
TRADE_MODE=paper
MAX_ORDER_AMOUNT_KRW=50000
ABSOLUTE_MAX_ORDER_KRW=500000
DAILY_LOSS_LIMIT_KRW=100000
MAX_POSITIONS=5
STOP_LOSS_PCT=-5.0
TAKE_PROFIT_PCT=10.0
TRAILING_STOP_PCT=0.0
TARGET_SYMBOLS=KRW-BTC,KRW-ETH

# === 전략 ===
STRATEGY_NAME=score
ENSEMBLE_STRATEGIES=rsi,macd,bollinger
MIN_CONFIDENCE=0.4
CANDLE_INTERVAL=minute240

# === 자동 종목 스크리닝 ===
AUTO_SELECT_SYMBOLS=false
TOP_VOLUME_LIMIT=10
MIN_DAILY_VOLUME_KRW=10000000000
SCREENING_INTERVAL_HOURS=24
MIN_BACKTEST_SHARPE=0.0
MAX_CORRELATION=0.9

# === 스케줄러 ===
SCHEDULE_INTERVAL_MINUTES=5
PAPER_INITIAL_BALANCE=1000000

# === AI 어시스턴트 (선택) ===
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ASK_DAILY_LIMIT=10

# === 자기개선 루프 (선택) ===
ENABLE_AUTO_OPTIMIZATION=false
# 현재 전략 기준값을 더 자주 미세조정할지 여부
ENABLE_AUTO_PARAMETER_TUNING=true
# 새 후보 파라미터가 이 정도 이상 Sharpe를 개선해야 실제 반영
PARAMETER_MIN_SHARPE_IMPROVEMENT=0.2
# 파라미터 자동조정 실행 주기 (시간)
PARAMETER_TUNING_INTERVAL_HOURS=6
# 마지막 조정 후 다시 조정하기 전 최소 대기 시간 (시간)
PARAMETER_TUNING_COOLDOWN_HOURS=12
# 튜닝 평가에 사용할 최근 캔들 개수
PARAMETER_TUNING_LOOKBACK_CANDLES=300
# Walk-Forward 검증 fold 수
PARAMETER_TUNING_N_FOLDS=3
# 튜닝 후보가 통과해야 하는 최소 Walk-Forward 일관성(%)
PARAMETER_TUNING_MIN_WF_CONSISTENCY=50.0

# === 웹 대시보드 (선택) ===
ENABLE_WEB=false
WEB_PORT=8090
# HTTP Basic Auth — 설정 시 대시보드 접근에 인증 필요 (미설정 시 인증 없이 접근 가능)
WEB_USERNAME=
WEB_PASSWORD=

# === 런타임 스케줄 / 타임존 ===
APP_TIMEZONE=Asia/Seoul
DAILY_SUMMARY_HOUR=9
DAILY_SUMMARY_MINUTE=0
SELF_IMPROVEMENT_DAY_OF_WEEK=sun
SELF_IMPROVEMENT_HOUR=3
SELF_IMPROVEMENT_MINUTE=0

# === 로깅 ===
LOG_LEVEL=INFO
LOG_FILE=
